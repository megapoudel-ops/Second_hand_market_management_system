PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/security-api
JWT_SECRET=replace-with-a-long-random-secret

# Optional: comma-separated DNS servers for MongoDB SRV lookup issues.
MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8

# Optional: MongoDB startup timeout in milliseconds.
MONGO_TIMEOUT_MS=10000
