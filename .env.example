NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/notification_api
MONGO_DNS_SERVERS=1.1.1.1,8.8.8.8
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Use console for local development logs, or smtp for a real SMTP provider.
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@secondhand-market.local

SMS_PROVIDER=console
PUSH_PROVIDER=console
