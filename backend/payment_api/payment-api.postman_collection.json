{
  "info": {
    "name": "Payment API — Marketplace",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:3000" },
    { "key": "buyerToken",     "value": "" },
    { "key": "sellerToken",    "value": "" },
    { "key": "buyerClientId",  "value": "" },
    { "key": "sellerClientId", "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register Buyer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "pm.collectionVariables.set('buyerToken', r.token);",
                "pm.collectionVariables.set('buyerClientId', r.clientId);",
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('Has token', () => pm.expect(r.token).to.be.a('string'));",
                "console.log('Buyer clientId:', r.clientId);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ram Buyer\",\n  \"email\": \"buyer@test.com\",\n  \"password\": \"pass123\",\n  \"role\": \"buyer\"\n}"
            }
          }
        },
        {
          "name": "Register Seller",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "pm.collectionVariables.set('sellerToken', r.token);",
                "pm.collectionVariables.set('sellerClientId', r.clientId);",
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "console.log('Seller clientId:', r.clientId);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sita Seller\",\n  \"email\": \"seller@test.com\",\n  \"password\": \"pass123\",\n  \"role\": \"seller\"\n}"
            }
          }
        },
        {
          "name": "Login Buyer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "pm.collectionVariables.set('buyerToken', r.token);",
                "pm.collectionVariables.set('buyerClientId', r.clientId);",
                "pm.test('Status 200', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@test.com\",\n  \"password\": \"pass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "💰 Wallet — Buyer",
      "item": [
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": "{{baseUrl}}/api/wallet/balance"
          }
        },
        {
          "name": "Initiate Deposit (eSewa)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/wallet/deposit/initiate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 2000,\n  \"gateway\": \"esewa\"\n}"
            }
          }
        },
        {
          "name": "Initiate Deposit (Khalti)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/wallet/deposit/initiate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1500,\n  \"gateway\": \"khalti\"\n}"
            }
          }
        },
        {
          "name": "Initiate Deposit (Bank)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/wallet/deposit/initiate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"gateway\": \"bank\"\n}"
            }
          }
        },
        {
          "name": "Confirm Deposit",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Deposit confirmed', () => pm.response.to.have.status(200));",
                "const r = pm.response.json();",
                "console.log('Balance after deposit:', r.transaction?.balanceAfter);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/wallet/deposit/confirm",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 2000,\n  \"gateway\": \"esewa\",\n  \"token\": \"mock-esewa-token-abc123\"\n}"
            }
          }
        },
        {
          "name": "Transaction History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/transactions?page=1&limit=10",
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Transaction History — Deposits only",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/wallet/transactions?type=DEPOSIT",
              "query": [{ "key": "type", "value": "DEPOSIT" }]
            }
          }
        }
      ]
    },
    {
      "name": "🛒 Purchase",
      "item": [
        {
          "name": "Buy Item (Buyer → Seller)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Purchase successful', () => pm.response.to.have.status(201));",
                "const r = pm.response.json();",
                "console.log('Fees charged:', JSON.stringify(r.fees));",
                "console.log('Seller received:', r.sellerTx?.net);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{buyerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/purchase",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sellerClientId\": \"{{sellerClientId}}\",\n  \"amount\": 1000,\n  \"orderId\": \"ORD-20250424-001\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "💸 Wallet — Seller",
      "item": [
        {
          "name": "Get Seller Balance",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }],
            "url": "{{baseUrl}}/api/wallet/balance"
          }
        },
        {
          "name": "Withdraw via eSewa",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/wallet/withdraw",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"gateway\": \"esewa\",\n  \"accountInfo\": {\n    \"esewaId\": \"9800000001\"\n  }\n}"
            }
          }
        },
        {
          "name": "Withdraw via Khalti",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/wallet/withdraw",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"gateway\": \"khalti\",\n  \"accountInfo\": {\n    \"khaltiId\": \"9800000001\"\n  }\n}"
            }
          }
        },
        {
          "name": "Withdraw via Bank",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/wallet/withdraw",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500,\n  \"gateway\": \"bank\",\n  \"accountInfo\": {\n    \"accountNumber\": \"0100123456789\",\n    \"bankName\": \"Nepal Bank Ltd\",\n    \"accountName\": \"Sita Seller\"\n  }\n}"
            }
          }
        },
        {
          "name": "Seller Transaction History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }],
            "url": "{{baseUrl}}/api/wallet/transactions"
          }
        }
      ]
    },
    {
      "name": "🛡️ Admin",
      "item": [
        {
          "name": "Platform Earnings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": "{{baseUrl}}/api/admin/earnings"
          }
        },
        {
          "name": "All Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": "{{baseUrl}}/api/admin/transactions"
          }
        },
        {
          "name": "All Clients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{buyerToken}}" }],
            "url": "{{baseUrl}}/api/admin/clients"
          }
        }
      ]
    },
    {
      "name": "❤️ Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    }
  ]
}
